# =============================================================================
# DevHub Frontend Environment Variables
# =============================================================================
#
# Copy this file to .env or .env.local and configure for your environment.
# Vite only exposes variables prefixed with VITE_
#
# For production builds, set VITE_API_BASE_URL to your production API endpoint.
# =============================================================================

# API Base URL - points to the backend API
# DEFAULT: http://localhost:8000/api/v1 (local development)
#
# Examples:
#   Development:  http://localhost:8000/api/v1
#   Staging:      https://staging-api.example.com/api/v1
#   Production:   https://api.example.com/api/v1
#
# IMPORTANT: The backend must have CORS configured to allow requests from
# the frontend origin. For local dev, this is typically http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
