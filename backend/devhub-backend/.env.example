# Django Core Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgres://devhub:devhub_local_password@postgres:5432/devhub

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Settings
JWT_ACCESS_LIFETIME_MINUTES=10
JWT_REFRESH_LIFETIME_DAYS=14

# Dev Admin Bootstrap (optional, for devhub_bootstrap_roles --create-admin)
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=changeme
DEV_ADMIN_EMAIL=admin@localhost

# Docker Access (for future docker_manager implementation)
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TLS_VERIFY=
DOCKER_CERT_PATH=

# Production Security (only used in prod.py)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Celery / Redis (Phase 5)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Set to True for testing (tasks run synchronously)
CELERY_TASK_ALWAYS_EAGER=False

# =============================================================================
# Phase 6: Security Hardening + Throttling + Observability
# =============================================================================

# Throttle Rates (requests per period)
# Format: "number/period" where period is one of: second, minute, hour, day
THROTTLE_RATE_ANON=30/min
THROTTLE_RATE_USER=120/min
THROTTLE_RATE_LOGIN=10/min
THROTTLE_RATE_DOCKER_MUTATION=30/min

# Django-Axes Login Throttling
# Lockout after N failed attempts
AXES_FAILURE_LIMIT=5
# Lockout duration in minutes
AXES_COOLOFF_MINUTES=15

# Cache (for axes and throttling)
# For production, use Redis:
# CACHE_REDIS_URL=redis://redis:6379/2
# For local dev, uses LocMemCache by default

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

# Production Security Headers (only used in prod.py)
# HSTS: Start with 60s for testing, raise to 31536000 (1 year) after verification
SECURE_HSTS_SECONDS=60
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
